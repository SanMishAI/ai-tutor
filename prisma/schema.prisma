generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id        String   @id
  userId    String
  title     String
  subject   String
  yearLevel String
  mode      String
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ExamResult {
  id           String   @id @default(cuid())
  userId       String
  childId      String?
  subject      String
  yearLevel    String
  score        Int
  total        Int
  timeTaken    Int?
  wrongAnswers Json
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([childId])
}

model PracticeResult {
  id        String   @id @default(cuid())
  userId    String
  childId   String?
  subject   String
  yearLevel String
  question  String
  correct   Boolean
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([childId])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String?
  mood      String
  message   String?
  createdAt DateTime @default(now())
}

model ArcadeProgress {
  id        String   @id @default(cuid())
  userId    String
  exam      String
  chapter   String
  stage     Int
  stars     Int      @default(0)
  xp        Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, exam, chapter, stage])
  @@index([userId, exam])
}

model UserStreak {
  id                String   @id @default(cuid())
  userId            String   @unique
  displayName       String   @default("Learner")
  currentStreak     Int      @default(0)
  longestStreak     Int      @default(0)
  lastActivityDate  String?
  freezesAvailable  Int      @default(0)
  showOnLeaderboard Boolean  @default(true)
  updatedAt         DateTime @updatedAt

  @@index([currentStreak])
}

model ChildProfile {
  id           String   @id @default(cuid())
  parentId     String
  name         String
  pinHash      String
  avatarEmoji  String   @default("🧑‍🎓")
  dailyLimit   Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dailyUsage   DailyUsage[]

  @@index([parentId])
}

model DailyUsage {
  id      String @id @default(cuid())
  childId String
  date    String
  count   Int    @default(0)

  child   ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, date])
}

model Subscription {
  id               String    @id @default(cuid())
  parentId         String    @unique
  stripeCustomerId String?
  stripePriceId    String?
  stripeSubId      String?
  status           String    @default("free")
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ChapterProgress {
  id        String   @id @default(cuid())
  userId    String
  childId   String?
  exam      String
  chapter   String
  phase     Int      @default(1)
  completed Boolean  @default(false)
  testScore Int?
  testTotal Int?
  updatedAt DateTime @updatedAt

  @@unique([userId, exam, chapter])
  @@index([userId, exam])
  @@index([childId, exam])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  location  String?
  quote     String
  rating    Int      @default(5)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}
